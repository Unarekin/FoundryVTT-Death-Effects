<div>
  {{#with effect}}
    {{> "modules/death-effects/templates/effects/partials/label.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/start.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/duration.hbs" }}

    <div class="form-group">
      <label for="{{@root.rootId}}-tint">{{localize
          "DEATH-EFFECTS.EFFECTS.FLASH.COLOR.LABEL"
        }}</label>
      <color-picker
        id="{{@root.rootId}}-color"
        name="color"
        value="{{color}}"
      ></color-picker>
      <p class="hint">{{localize "DEATH-EFFECTS.EFFECTS.FLASH.COLOR.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{@root.rootId}}-replace">{{localize "DEATH-EFFECTS.EFFECTS.FLASH.REPLACE.LABEL"}}</label>
      <input type="checkbox" id="{{@root.rootId}}-replace" name="replace" {{checked replace}}>
      <p class="hint">{{localize "DEATH-EFFECTS.EFFECTS.FLASH.REPLACE.LABEL"}}</p>
    </div>
  {{/with}}
</div>