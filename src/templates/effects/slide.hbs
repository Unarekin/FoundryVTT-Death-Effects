<div>
  {{log "Slide context" this}}
  {{#with effect}}
    {{> "modules/death-effects/templates/effects/partials/label.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/start.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/duration.hbs" }}

    <div class="form-group">
      <label for="{{@root.rootId}}-direction">{{localize "DEATH-EFFECTS.EFFECTS.SLIDE.DIRECTION.LABEL"}}</label>
      <select id="{{@root.rootId}}-direction" name="direction">
        {{selectOptions ../directionSelect selected=direction localize=true}}
      </select>
      <p class="hint">{{localize "DEATH-EFFECTS.EFFECTS.SLIDE.DIRECTION.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{@root.rootId}}-distance">{{localize "DEATH-EFFECTS.EFFECTS.SLIDE.DISTANCE.LABEL"}}</label>
      <input type="number" min="0" step="1" required id="{{@root.rootId}}-distance" name="distance" value="{{distance}}">
      <p class="hint">{{localize "DEATH-EFFECTS.EFFECTS.SLIDE.DISTANCE.HINT"}}</p>
    </div>
  {{/with}}
  {{> "modules/death-effects/templates/effects/partials/easing.hbs" }}
</div>