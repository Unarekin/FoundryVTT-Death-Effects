<div>
  {{#with effect}}
    {{> "modules/death-effects/templates/effects/partials/label.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/start.hbs" }}
    {{> "modules/death-effects/templates/effects/partials/duration.hbs" }}

    <div class="form-group">
      <label for="{{@root.rootId}}-strength">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.STRENGTH.LABEL"
        }}</label>
      <input
        type="number"
        id="{{@root.rootId}}-strength"
        name="strength"
        value="{{strength}}"
        min="0"
        step="any"
      />
      <p class="hint">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.STRENGTH.HINT"
        }}</p>
    </div>

    <div class="form-group">
      <label for="{{@root.rootId}}-horizontal">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.HORIZONTAL.LABEL"
        }}</label>
      <input
        type="checkbox"
        id="{{@root.rootId}}-horizontal"
        name="horizontal"
        {{checked horizontal}}
      />
      <p class="hint">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.HORIZONTAL.HINT"
        }}</p>
    </div>

    <div class="form-group">
      <label for="{{@root.rootId}}-vertical">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.VERTICAL.LABEL"
        }}</label>
      <input
        type="checkbox"
        id="{{@root.rootId}}-vertical"
        name="vertical"
        {{checked vertical}}
      />
      <p class="hint">{{localize
          "DEATH-EFFECTS.EFFECTS.SHAKE.VERTICAL.HINT"
        }}</p>
    </div>
  {{/with}}
  {{> "modules/death-effects/templates/effects/partials/easing.hbs" }} 
</div>